# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sat_user
DB_PASSWORD=sat_password
DB_DATABASE=sat_reading

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — CHANGE THESE in production
JWT_SECRET=CHANGE_ME_generate_a_random_string
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_random_string
JWT_REFRESH_EXPIRATION=7d

# App
PORT=3000
NODE_ENV=development

# LLM Provider: bedrock | openai | anthropic
# AI features (coaching, tips, exercise generation) are optional.
# If no provider is configured, the app still works for practice and review.
LLM_PROVIDER=bedrock

# AWS Bedrock (default) — uses IAM role credentials (no API key needed)
AWS_REGION=us-east-1
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# OpenAI — set LLM_PROVIDER=openai to use
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com

# Anthropic — set LLM_PROVIDER=anthropic to use
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# AI Service (Python/FastAPI — IRT calibration)
AI_SERVICE_URL=http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
